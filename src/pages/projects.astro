---
// src/pages/projects.astro
import BaseLayout from '@layouts/BaseLayout.astro';

// Replace with real data or a CMS/content collection later
const projects = [
  {
    title: 'Project One',
    description: 'Short description of what this project is and what problem it solves.',
    tags: ['React', 'TypeScript'],
    href: '#',
  },
  {
    title: 'Project Two',
    description: 'Short description of what this project is and what problem it solves.',
    tags: ['Astro', 'Tailwind'],
    href: '#',
  },
  {
    title: 'Project Three',
    description: 'Short description of what this project is and what problem it solves.',
    tags: ['Node.js', 'API'],
    href: '#',
  },
];
---

<BaseLayout title="Projects | yourname" description="Things I've built">
  <h1 class="text-4xl font-bold tracking-tight">Projects</h1>
  <p class="mt-3 text-gray-500">A selection of things I've worked on.</p>

  <ul class="mt-10 space-y-6">
    {projects.map((project) => (
      <li class="group rounded-xl border border-gray-100 p-6 transition hover:border-gray-300">
        <a href={project.href} class="flex items-start justify-between gap-4">
          <div>
            <h2 class="font-semibold group-hover:underline">{project.title}</h2>
            <p class="mt-1 text-sm text-gray-500">{project.description}</p>
            <ul class="mt-3 flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <li class="rounded-full bg-gray-100 px-3 py-0.5 text-xs text-gray-600">{tag}</li>
              ))}
            </ul>
          </div>
          <span class="mt-0.5 text-gray-300 group-hover:text-gray-600">→</span>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
