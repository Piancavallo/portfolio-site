---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Games | Conner Myers">
  <div class="relative z-10 w-full max-w-4xl mx-auto px-8 sm:px-6 md:px-16 py-16">
    <main class="space-y-6">
      <h1 class="text-4xl font-bold text-[#243547]">Web demos</h1>
      <p class="text-[#3e4b58] leading-relaxed max-w-2xl">
        Playable Unity WebGL builds will live here. For now, check the
        <a
          href="https://github.com/Piancavallo"
          target="_blank"
          rel="noopener noreferrer"
          class="underline underline-offset-2 text-[#8b2725] hover:text-[#c96f4a] transition-colors"
        >
          GitHub profile
        </a>
        for source and readmes. When you export a build, you can drop it under <code class="text-sm bg-[#f6f2ea] px-1.5 py-0.5 rounded border border-[#d8cfc0]">public/games/&lt;name&gt;/</code> and link or embed it from this page.
      </p>
      <p>
        <a href="/" class="text-sm text-[#6b7280] underline underline-offset-2 hover:text-[#c96f4a] transition-colors">
          Back to home
        </a>
      </p>
    </main>
  </div>
</BaseLayout>
