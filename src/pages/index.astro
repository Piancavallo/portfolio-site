---
import BaseLayout from '@layouts/BaseLayout.astro';
import PortfolioMap from '@components/PortfolioMap';
---

<BaseLayout title="Conner Myers">
  <div class="home-page">
  <div class="relative z-10 w-full max-w-4xl mx-auto px-8 sm:px-6 md:px-16">

    <!-- Map -->
    <div class="relative home-map-row">
      <div class="map-panel">
        <div class="map-panel__inner overflow-hidden">
          <PortfolioMap client:only="react" />
        </div>
      </div>
      <div class="portrait-anchor absolute bottom-2 right-8 z-20" style="transform: translateY(50%);">
        <div class="chart-portrait">
          <div class="chart-portrait__ring">
            <img
              src="/images/Me.jpg"
              alt="Conner Myers"
              class="chart-portrait__photo w-40 h-40 object-cover"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- Page content -->
    <main class="home-main">
      <div class="home-main__content space-y-6">

      <!-- Intro -->
      <h1 class="text-5xl font-bold">Conner Myers</h1>
      <p class="waypoint-body max-w-4xl">
        Hi, I'm Conner. I graduated in May 2026 with a B.S. in computer science/cybersecurity from Liberty University. I am currently in Denton, Maryland.
      </p>

      <!-- Work Experience -->
      <h2 class="section-header">Work Experience</h2>

      <p class="card-excerpt">In 2017 I enlisted in the United States Air Force. During my four year term I traveled to California, Colorado and New Mexico to work on military satellite communications (MILSATCOM). View my full work history on LinkedIn by clicking the card below, or find my resume at the bottom of the page. </p>
      <div class="card-row">
        <a
          href="https://www.linkedin.com/in/conner-myers-0411481b1/"
          target="_blank"
          rel="noopener noreferrer"
          class="waypoint-card waypoint-card--usaf"
          style="--card-bg: url('/images/cards/usaf.jpg')"
        >
          <h3 class="card-label">USAF / MILSATCOM (2017 - 2021)</h3>
          <div class="card-overlay">
            <p class="waypoint-action">See my full work history on LinkedIn <span aria-hidden="true">&rarr;</span></p>
          </div>
        </a>
      </div>

      <!-- Projects -->
      <h2 class="section-header">Projects</h2>

      <p class="card-excerpt">In university I got curious about game development so I took a free course online for Unity. You can check out two prototype games I built below. Note: curb your expectations. </p>
      <div class="card-row">
        <div class="waypoint-card waypoint-card--unity"
          style="--card-bg: url('/images/cards/Unity.webp')"
        >
          <h3 class="card-label">Unity Game Dev Course</h3>
          <div class="card-overlay unity-split-overlay">
            <div class="unity-split-row">
              <a
                href="https://piancavallo.itch.io/unity-vehicle-demo"
                target="_blank"
                rel="noopener noreferrer"
                class="unity-split-link"
                style="--card-bg: url('/images/Unity Tank driving thumbnail.jpg')"
              >
                <span class="unity-split-title">Tank Driver's Ed</span>
                <span class="unity-split-action">Play game <span aria-hidden="true">&rarr;</span></span>
              </a>
              <a
                href="https://piancavallo.itch.io/soccer"
                target="_blank"
                rel="noopener noreferrer"
                class="unity-split-link"
                style="--card-bg: url('/images/Soccer.jpg')"
              >
                <span class="unity-split-title">Soccer</span>
                <span class="unity-split-action">Play game <span aria-hidden="true">&rarr;</span></span>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- About Me -->
      <h2 class="section-header">About Me</h2>

      <p class="card-excerpt">I spent the summer and fall of 2023 living and working on an organic farm in north-western Arkansas. I've since found great joy in growing my own food.</p>
      <div class="card-row">
        <a href="/media?tab=garden" class="waypoint-card waypoint-card--garden"
          style="--card-bg: url('/images/cards/garden.jpg')"
        >
          <h3 class="card-label">Backyard Garden</h3>
          <div class="card-overlay">
            <p class="waypoint-action">View garden <span aria-hidden="true">&rarr;</span></p>
          </div>
        </a>
      </div>

      <p class="card-excerpt">I like to read, you can see what I've been reading here: </p>
      <div class="card-row">
        <a href="/media?tab=books" class="waypoint-card waypoint-card--media"
          style="--card-bg: url('/images/cards/library.webp')"
        >
          <h3 class="card-label">Library</h3>
          <div class="card-overlay">
            <p class="waypoint-action">Browse library <span aria-hidden="true">&rarr;</span></p>
          </div>
        </a>
      </div>
      </div>

      <!-- Connect -->
      <h2 class="section-header">Contact</h2>
      <div class="contact-stamps" aria-label="Contact links">
        <a
          href="https://www.linkedin.com/in/conner-myers-0411481b1/"
          target="_blank"
          rel="noopener noreferrer"
          class="stamp-button stamp-button--linkedin"
        >
          LinkedIn
        </a>
        <a
          href="https://github.com/Piancavallo"
          target="_blank"
          rel="noopener noreferrer"
          class="stamp-button stamp-button--github"
        >
          GitHub
        </a>
        <button
          id="email-copy-button"
          type="button"
          data-email="conn0myers@gmail.com"
          class="stamp-button stamp-button--email"
        >
          <span class="stamp-button__default">Email</span>
          <span class="stamp-button__copied" aria-hidden="true">Copied</span>
        </button>
        <a
          href="/Conner_Myers_Resume.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="stamp-button stamp-button--resume"
          title="Open resume (PDF)"
        >
          Resume
        </a>
      </div>

      <script>
        const emailButton = document.getElementById('email-copy-button');
        let copyFeedbackTimeout: ReturnType<typeof setTimeout> | null = null;
      
        emailButton?.addEventListener('click', async () => {
          const email = emailButton.dataset.email;
      
          if (!email) return;
      
          await navigator.clipboard.writeText(email);

          emailButton.classList.add('is-copied');
          if (copyFeedbackTimeout) {
            clearTimeout(copyFeedbackTimeout);
          }
          copyFeedbackTimeout = setTimeout(() => {
            emailButton.classList.remove('is-copied');
          }, 1250);
        });

      </script>
      
      <style>
        .home-page {
          position: relative;
          isolation: isolate;
        }

        .home-page::before {
          content: '';
          position: fixed;
          inset: 0;
          z-index: 0;
          pointer-events: none;
          opacity: 0.12;
          background:
            repeating-linear-gradient(
              90deg,
              transparent 0 47px,
              rgba(42, 58, 74, 0.4) 47px 48px
            ),
            repeating-linear-gradient(
              0deg,
              transparent 0 47px,
              rgba(42, 58, 74, 0.32) 47px 48px
            ),
            repeating-linear-gradient(
              128deg,
              transparent 0 140px,
              rgba(115, 74, 40, 0.15) 140px 141px
            );
        }

        .map-panel {
          position: relative;
          border-radius: 2px;
          border: 1px solid #2a3a4a;
          background-color: #f4ead8;
          background-image: linear-gradient(165deg, #f7ecd7 0%, #efe2c8 55%, #e8d9b8 100%);
          box-shadow:
            0 10px 22px rgba(42, 36, 28, 0.12),
            inset 0 0 0 1px rgba(255, 252, 244, 0.85),
            inset 0 0 0 3px #f0e4cf,
            inset 0 0 0 4px #2a3a4a;
          overflow: hidden;
        }

        .map-panel::before {
          content: '';
          position: absolute;
          inset: 0;
          border-radius: 2px;
          pointer-events: none;
          z-index: 0;
          background:
            repeating-linear-gradient(
              90deg,
              transparent 0 10px,
              rgba(42, 58, 74, 0.14) 10px 11px
            ),
            repeating-linear-gradient(
              0deg,
              transparent 0 10px,
              rgba(42, 58, 74, 0.14) 10px 11px
            ),
            radial-gradient(circle at 10% 12%, rgba(115, 74, 40, 0.08) 0%, transparent 24%),
            radial-gradient(circle at 92% 88%, rgba(115, 74, 40, 0.06) 0%, transparent 26%);
          background-size: 100% 11px, 11px 100%, auto, auto;
          background-position: top left, top left, center, center;
          background-repeat: repeat-x, repeat-y, no-repeat, no-repeat;
          opacity: 0.85;
        }

        .map-panel::after {
          content: '';
          position: absolute;
          inset: 6px;
          border-radius: 1px;
          pointer-events: none;
          z-index: 0;
          border: 1px solid rgba(42, 58, 74, 0.35);
          background:
            linear-gradient(#243547, #243547) top 5px left 5px / 12px 2px no-repeat,
            linear-gradient(#243547, #243547) top 5px left 5px / 2px 12px no-repeat,
            linear-gradient(#243547, #243547) top 5px right 5px / 12px 2px no-repeat,
            linear-gradient(#243547, #243547) top 5px right 5px / 2px 12px no-repeat,
            linear-gradient(#243547, #243547) bottom 5px left 5px / 12px 2px no-repeat,
            linear-gradient(#243547, #243547) bottom 5px left 5px / 2px 12px no-repeat,
            linear-gradient(#243547, #243547) bottom 5px right 5px / 12px 2px no-repeat,
            linear-gradient(#243547, #243547) bottom 5px right 5px / 2px 12px no-repeat;
        }

        .map-panel__inner {
          position: relative;
          z-index: 1;
        }

        .map-panel::before,
        .map-panel::after {
          z-index: 2;
        }

        .section-header {
          margin-top: 0.75rem;
          margin-bottom: 0.5rem;
          font-size: 1.55rem;
          font-weight: 600;
          letter-spacing: 0.12em;
          text-transform: uppercase;
          color: #243547;
          border-bottom: 2px dashed #000;
          padding-bottom: 0.35rem;
          display: block;
        }

        .card-excerpt {
          font-size: 1rem;
          line-height: 1.5;
          color: #3a4a5a;
          margin: 0.25rem 0 0.5rem;
        }

        .card-row {
          margin-bottom: 1rem;
        }

        .card-row--pair {
          display: flex;
          flex-direction: column;
          gap: 1rem;
        }

        @media (min-width: 768px) {
          .card-row--pair {
            flex-direction: row;
            align-items: flex-start;
          }
          .card-row--pair > .waypoint-card {
            flex: 1 1 0;
          }
        }

        .card-row[hidden] {
          display: none;
        }

        .waypoint-card {
          position: relative;
          display: flex;
          flex-direction: column;
          justify-content: flex-end;
          text-align: left;
          text-decoration: none;
          color: inherit;
          border-radius: 2px;
          border: 1px solid #2a3a4a;
          min-height: 220px;
          padding: 0;
          background: var(--card-bg) center / cover no-repeat;
          background-color: #3b4a5a;
          box-shadow:
            0 10px 22px rgba(42, 36, 28, 0.12),
            inset 0 0 0 1px rgba(255, 252, 244, 0.25);
          overflow: hidden;
          cursor: pointer;
          transition: transform 280ms ease, box-shadow 280ms ease, border-color 280ms ease;
        }

        .card-row--pair > .waypoint-card {
          min-height: 220px;
        }

        .waypoint-card::before {
          display: none;
        }

        .waypoint-card::after {
          content: '';
          position: absolute;
          inset: 6px;
          border-radius: 1px;
          pointer-events: none;
          z-index: 1;
          background:
            linear-gradient(#243547, #243547) top 5px left 5px / 12px 2px no-repeat,
            linear-gradient(#243547, #243547) top 5px left 5px / 2px 12px no-repeat,
            linear-gradient(#243547, #243547) top 5px right 5px / 12px 2px no-repeat,
            linear-gradient(#243547, #243547) top 5px right 5px / 2px 12px no-repeat,
            linear-gradient(#243547, #243547) bottom 5px left 5px / 12px 2px no-repeat,
            linear-gradient(#243547, #243547) bottom 5px left 5px / 2px 12px no-repeat,
            linear-gradient(#243547, #243547) bottom 5px right 5px / 12px 2px no-repeat,
            linear-gradient(#243547, #243547) bottom 5px right 5px / 2px 12px no-repeat;
        }

        .waypoint-card:hover {
          transform: translateY(-6px);
          border-color: #1e2d3d;
          box-shadow: 0 10px 10px -6px rgba(36, 53, 71, 0.3);
        }

        .waypoint-card:focus-visible {
          outline: 2px solid #c96f4a;
          outline-offset: 4px;
        }

        .waypoint-card.is-active {
          border-color: #1e2d3d;
          box-shadow:
            0 18px 32px rgba(42, 36, 28, 0.22),
            inset 0 0 0 1px rgba(255, 252, 244, 0.4),
            0 0 0 1px rgba(42, 58, 74, 0.3);
        }

        /* Always-visible card title badge */
        .card-label {
          position: absolute;
          top: 1.1rem;
          left: 1.1rem;
          z-index: 3;
          margin: 0;
          padding: 0.45rem 0.9rem;
          font-size: 0.85rem;
          font-weight: 700;
          letter-spacing: 0.04em;
          color: #243547;
          background: rgba(244, 234, 216, 0.94);
          border: 1px solid #2a3a4a;
          border-radius: 3px;
          box-shadow: 0 2px 6px rgba(0, 0, 0, 0.18);
          pointer-events: none;
          transition: opacity 280ms ease;
        }

        .waypoint-card:hover .card-label,
        .waypoint-card:focus-within .card-label {
          opacity: 0;
        }

        /* Hover/focus overlay with text */
        .card-overlay {
          position: absolute;
          bottom: 0.75rem;
          right: 0.75rem;
          z-index: 4;
          opacity: 0;
          transform: translateY(4px);
          transition: opacity 280ms ease, transform 280ms ease;
          pointer-events: none;
        }

        .waypoint-card:hover .card-overlay,
        .waypoint-card:focus-within .card-overlay {
          opacity: 1;
          transform: translateY(0);
          pointer-events: auto;
        }

        .waypoint-eyebrow {
          margin: 0 0 0.3rem;
          padding: 0;
          font-size: 0.68rem;
          font-weight: 600;
          letter-spacing: 0.2em;
          text-transform: uppercase;
          text-align: center;
          color: #6b7280;
        }

        .waypoint-title {
          margin: 0;
          padding: 0;
          font-size: 1.3rem;
          font-weight: 700;
          text-align: center;
          color: #243547;
          letter-spacing: 0.01em;
        }

        .card-overlay .waypoint-body {
          color: #3e4b58;
          text-align: center;
          font-size: 0.85rem;
          margin-top: 0.4rem;
        }

        .waypoint-action {
          margin: 0;
          padding: 0.4rem 0.8rem;
          font-size: 0.78rem;
          font-weight: 700;
          letter-spacing: 0.04em;
          color: #243547;
          background: rgba(244, 234, 216, 0.94);
          border: 1px solid #2a3a4a;
          border-radius: 3px;
          box-shadow: 0 2px 6px rgba(0, 0, 0, 0.18);
          transition: background 180ms ease, color 180ms ease;
        }

        .waypoint-card:hover .waypoint-action {
          background: rgba(244, 234, 216, 1);
          color: #8b2725;
        }

        /* Placeholder gradients for cards without images yet */
        .waypoint-card--usaf {
          --card-bg: linear-gradient(135deg, #3b4f6b 0%, #2a3a4f 40%, #1e2d3d 100%);
        }

        .waypoint-card--unity {
          cursor: default;
        }

        .unity-split-overlay {
          inset: 7px;
          bottom: 7px;
          right: 7px;
          display: flex;
          flex-direction: column;
          padding: 0.4rem;
          gap: 0.4rem;
          background: transparent;
        }

        .unity-split-header {
          padding: 0.75rem 0.9rem 0.6rem;
          text-align: center;
          border: 1px solid #2a3a4a;
          border-radius: 2px;
          background: rgba(244, 234, 216, 0.95);
        }

        .unity-split-header .waypoint-eyebrow {
          color: #6b7280;
        }

        .unity-split-header .waypoint-title {
          color: #243547;
        }

        .unity-split-header .waypoint-body {
          color: #3e4b58;
          text-align: center;
          font-size: 0.82rem;
          margin-top: 0.3rem;
        }

        .unity-split-row {
          display: flex;
          flex: 1;
          gap: 0.4rem;
        }

        .unity-split-link {
          position: relative;
          flex: 1 1 0;
          display: flex;
          flex-direction: column;
          justify-content: flex-end;
          padding: 0.75rem 0.85rem;
          text-decoration: none;
          color: #fff;
          background: var(--card-bg) center / cover no-repeat;
          background-color: #2a3a4a;
          border: 1px solid #2a3a4a;
          border-radius: 2px;
          transition: transform 200ms ease, box-shadow 200ms ease;
        }

        .unity-split-link::after {
          content: '';
          position: absolute;
          inset: 0;
          border-radius: 2px;
          background: rgba(20, 30, 42, 0.4);
          transition: background 200ms ease;
        }

        .unity-split-link:hover {
          transform: translateY(-3px);
          box-shadow: 0 4px 10px rgba(42, 36, 28, 0.18);
        }

        .unity-split-link:hover::after {
          background: rgba(20, 30, 42, 0.12);
        }

        .unity-split-title {
          position: absolute;
          top: 0.55rem;
          left: 0.55rem;
          z-index: 1;
          padding: 0.35rem 0.7rem;
          font-size: 0.78rem;
          font-weight: 700;
          letter-spacing: 0.04em;
          color: #243547;
          background: rgba(244, 234, 216, 0.94);
          border: 1px solid #2a3a4a;
          border-radius: 3px;
          box-shadow: 0 2px 6px rgba(0, 0, 0, 0.18);
        }

        .unity-split-action {
          position: absolute;
          bottom: 0.5rem;
          right: 0.5rem;
          z-index: 1;
          font-size: 0.68rem;
          font-weight: 600;
          letter-spacing: 0.06em;
          color: #e8926e;
          text-shadow: 0 1px 4px rgba(0, 0, 0, 0.4);
          transition: color 180ms ease;
        }

        .unity-split-link:hover .unity-split-action {
          color: #f4a882;
        }

        .waypoint-card--garden {
          --card-bg: linear-gradient(145deg, #4a6741 0%, #3a5535 40%, #2d4228 100%);
        }

        .waypoint-card--media {
          --card-bg: linear-gradient(140deg, #7a5c3a 0%, #5c4428 40%, #3e2f1c 100%);
        }

        /* Touch devices: always show overlay since no hover */
        @media (hover: none) {
          .card-overlay {
            opacity: 1;
            transform: translateY(0);
            pointer-events: auto;
          }
        }

        .waypoint-body {
          margin-top: 0.46rem;
          font-size: 1rem;
          line-height: 1.5;
          text-align: left;
          color: #3e4b58;
        }

        .waypoint-body a,
        footer a {
          color: #8b2725;
        }

        .waypoint-body a:hover,
        footer a:hover {
          color: #c96f4a;
        }

        .chart-portrait {
          position: relative;
          display: inline-block;
          transform: rotate(-3deg);
          filter: saturate(1.04);
        }

        .chart-portrait__ring {
          position: relative;
          display: block;
          padding: 0.62rem;
          border-radius: 9999px;
          border: 2px solid rgba(138, 46, 44, 0.82);
          background:
            radial-gradient(circle at 32% 24%, rgba(255, 246, 241, 0.75) 0%, transparent 56%),
            radial-gradient(circle at 76% 76%, rgba(130, 34, 31, 0.19) 0%, transparent 52%),
            linear-gradient(150deg, #f6dfd7 0%, #ebc1b0 52%, #e2b09d 100%);
          box-shadow:
            0 10px 22px rgba(79, 32, 29, 0.24),
            inset 0 0 0 2px rgba(246, 205, 192, 0.92),
            inset 0 0 0 7px rgba(155, 54, 51, 0.24),
            inset 0 0 0 8px rgba(104, 28, 26, 0.62);
          overflow: hidden;
        }

        .chart-portrait__ring::before {
          content: '';
          position: absolute;
          inset: 4px;
          border-radius: 9999px;
          border: 1px dashed rgba(139, 39, 37, 0.6);
          opacity: 0.65;
          pointer-events: none;
        }

        .chart-portrait__ring::after {
          content: '';
          position: absolute;
          inset: 0;
          border-radius: 9999px;
          pointer-events: none;
          background:
            radial-gradient(circle, rgba(122, 30, 27, 0.16) 0 0.9px, transparent 1px) 0 0 / 5px 5px,
            radial-gradient(circle at 72% 34%, rgba(95, 22, 20, 0.2) 0%, transparent 34%);
          mix-blend-mode: multiply;
          opacity: 0.5;
        }

        .chart-portrait__photo {
          position: relative;
          z-index: 1;
          display: block;
          border-radius: 9999px;
          border: 2px solid rgba(126, 33, 31, 0.42);
          box-shadow: inset 0 0 0 1px rgba(246, 222, 212, 0.9);
          image-rendering: auto;
          filter: saturate(1.02) contrast(1.03);
        }

        .home-main {
          display: flex;
          flex-direction: column;
          min-height: calc(100svh - 18rem);
          padding-top: 4rem;
          padding-bottom: 0;
        }

        .home-main__content {
          flex: 0 0 auto;
        }

        .contact-stamps {
          display: flex;
          justify-content: flex-start;
          align-items: center;
          flex-wrap: wrap;
          gap: 0.55rem;
          margin-top: auto;
          padding-top: clamp(0.5rem, 3vh, 1.5rem);
          padding-bottom: 0.75rem;
        }

        .stamp-button {
          position: relative;
          display: inline-flex;
          align-items: center;
          justify-content: center;
          min-width: 5.85rem;
          padding: 0.55rem 0.95rem;
          border: 1px solid #2a3a4a;
          border-radius: 2px;
          background-color: #f4ead8;
          background-image: linear-gradient(165deg, #f7ecd7 0%, #efe2c8 55%, #e8d9b8 100%);
          color: #2f3a45;
          font-size: 0.72rem;
          font-weight: 700;
          letter-spacing: 0.08em;
          text-transform: uppercase;
          line-height: 1;
          box-shadow:
            0 7px 14px rgba(42, 36, 28, 0.12),
            inset 0 0 0 1px rgba(255, 252, 244, 0.85),
            inset 0 0 0 3px #f0e4cf,
            inset 0 0 0 4px #2a3a4a;
          text-decoration: none;
          transition:
            transform 180ms ease,
            box-shadow 220ms ease,
            border-color 220ms ease,
            background-color 220ms ease,
            background-image 220ms ease,
            color 220ms ease;
          overflow: hidden;
          cursor: pointer;
        }

        .stamp-button::before {
          content: '';
          position: absolute;
          inset: 0;
          border-radius: 2px;
          pointer-events: none;
          z-index: 0;
          background:
            repeating-linear-gradient(
              90deg,
              transparent 0 10px,
              rgba(42, 58, 74, 0.14) 10px 11px
            ),
            repeating-linear-gradient(
              0deg,
              transparent 0 10px,
              rgba(42, 58, 74, 0.14) 10px 11px
            );
          background-size: 100% 11px, 11px 100%;
          background-position: top left, top left;
          background-repeat: repeat-x, repeat-y;
          opacity: 0.85;
