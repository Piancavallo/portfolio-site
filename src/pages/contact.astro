---
// src/pages/contact.astro
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Contact | Conner Myers" description="Get in touch">
  <h1 class="text-4xl font-bold tracking-tight">Contact</h1>
  <p class="mt-3 max-w-lg text-gray-500">
    Have a project in mind or just want to say hi? Reach out through any of the
    channels below.
  </p>

  <ul class="mt-10 space-y-4 text-sm">
    <li class="flex items-center gap-3">
      <span class="w-20 text-gray-400">Email</span>
      <a href="mailto:you@example.com" class="hover:underline">you@example.com</a>
    </li>
    <li class="flex items-center gap-3">
      <span class="w-20 text-gray-400">GitHub</span>
      <a href="https://github.com/yourusername" target="_blank" rel="noopener" class="hover:underline">
        github.com/yourusername
      </a>
    </li>
    <li class="flex items-center gap-3">
      <span class="w-20 text-gray-400">LinkedIn</span>
      <a href="https://linkedin.com/in/yourusername" target="_blank" rel="noopener" class="hover:underline">
        linkedin.com/in/yourusername
      </a>
    </li>
  </ul>
</BaseLayout>
